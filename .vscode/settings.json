{
	"files.exclude": {
		"build": false
	},
	"search.exclude": {
		"build": true
	},
	// Turn off tsc task auto detection since we have the necessary tasks as npm scripts
	"typescript.tsc.autoDetect": "off",
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"json.schemas": [
		{
			"fileMatch": [
                "src/Effects/*/*.jsonc",
                "!src/Effects/*/tsconfig.json",
                "!src/Effects/EffectConfigOrdering.json"
			],
			"url": "./schemas/EffectConfig.schema.json"
		},
		{
			"fileMatch": [
				"src/Effects/EffectConfigOrdering.json"
			],
			"url": "./schemas/EffectConfigOrderingFile.schema.json"
		},
		{
			"fileMatch": [
				"bundler/GlyphConfig.json"
			],
			"url": "./schemas/ExtensionGlyphConfig.schema.json"
		}
	],
	"cSpell.words": [
		"componentized",
		"exmarkdown",
		"gsap",
		"ibwrapper",
		"iconified",
		"oklch",
		"ondisabledclick",
		"rgba",
		"shadcn",
		"Slerp",
		"srgb",
		"unfocus",
		"vsbloom",
		"WGSL"
	],
}
