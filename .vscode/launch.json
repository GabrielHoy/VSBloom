{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run VSBloom",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/build/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"env": {
				"VSBLOOM_DEVELOPMENT_MODE": "true"
			}
		},
		{
			"name": "Run VSBloom (Isolated)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--disable-extensions"
			],
			"outFiles": [
				"${workspaceFolder}/build/**/*.js"
			],
			"preLaunchTask": "${defaultBuildTask}",
			"env": {
				"VSBLOOM_DEVELOPMENT_MODE": "true"
			}
		}
	]
}
