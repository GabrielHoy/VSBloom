{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": {
				"owner": "typescript",
				"fileLocation": ["relative", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^✘ \\[ERROR\\] (.+)$",
					"message": 1
				},
				"background": {
					"activeOnStart": true,
				"beginsPattern": "^(?:\u001b\\[[0-9;]*m)*\\[watch\\]\\s+(?:\u001b\\[[0-9;]*m)*[Bb]uild\\s+(?:\u001b\\[[0-9;]*m)*started",
				"endsPattern": "^(?:\u001b\\[[0-9;]*m)*\\[watch\\]\\s+(?:\u001b\\[[0-9;]*m)*[Bb]uild\\s+(?:\u001b\\[[0-9;]*m)*[Ff]inished"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
